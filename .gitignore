# =====================================================
# QuantEdge .gitignore
# =====================================================

# ---- Secrets (NEVER commit) ----
.env
.env.local
.env.*.local
*.key
*.pem
secrets.json
credentials.json

# ---- Dados pessoais ----
transactions.csv

# ---- Python ----
venv/
env/
.venv/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ---- Testing / Coverage ----
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# ---- Jupyter ----
.ipynb_checkpoints/
*.ipynb_checkpoints

# ---- Editores / IDEs ----
.vscode/
.idea/
.claude/
*.swp
*.swo
*~
.project
.pydevproject

# ---- OS ----
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# ---- Dados locais / Outputs ----
*.db
*.sqlite
*.sqlite3
instance/
logs/
*.log

# ---- Backups ----
*.bak
*.tmp
*.old
