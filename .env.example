# QuantEdge — Environment Variables (TEMPLATE)
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in your real values.
# NEVER commit the real `.env` to Git — it is listed in .gitignore.
#
# Local usage:  python-dotenv reads `.env` automatically when app.py starts.
# Production:   set these as environment variables in Railway/Render/Heroku.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# FMP Premium API key — https://financialmodelingprep.com/developer/docs
FMP_API_KEY=your_fmp_api_key_here

# PostgreSQL connection string
# Local:      postgresql://user:password@localhost:5432/quantedge
# Railway:    provided automatically as $DATABASE_URL
# Heroku:     provided automatically as $DATABASE_URL
DATABASE_URL=postgresql://user:password@localhost:5432/quantedge


# ── Email alerts (optional) ───────────────────────────────────────────────────
# Gmail: use an App Password (not your account password)
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
ALERT_FROM=your_email@gmail.com


# ── Data settings ─────────────────────────────────────────────────────────────

# How many years of price history to fetch on setup
YEARS_BACK=10

# Screener universe size:
#   "all"            → all ~7000 FMP tickers (setup takes ~40 min)
#   500              → top 500 by market cap (setup takes ~8 min, recommended)
#   "AAPL,MSFT,..."  → specific tickers only
SCREENER_UNIVERSE=all


# ── App server ────────────────────────────────────────────────────────────────

# Set to "false" in production
DEBUG=true
PORT=8050
HOST=127.0.0.1


# ── Nightly scheduler (UTC) ───────────────────────────────────────────────────
# Prices refresh at HH:MM UTC every day
NIGHTLY_CRON_HOUR=22
NIGHTLY_CRON_MINUTE=0
