# QuantEdge — Environment Variables (TEMPLATE)
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in your real values.
# NEVER commit the real `.env` to Git — it is listed in .gitignore.
#
# Local usage:  python-dotenv reads `.env` automatically when app.py starts.
# Production:   set these as environment variables in Railway/Render/Heroku.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# FMP Premium API key — https://financialmodelingprep.com/developer/docs
FMP_API_KEY=your_fmp_api_key_here

# PostgreSQL connection string
# Local:      postgresql://user:password@localhost:5432/quantedge
# Railway:    provided automatically as $DATABASE_URL
# Heroku:     provided automatically as $DATABASE_URL
DATABASE_URL=postgresql://user:password@localhost:5432/quantedge


# ── Email alerts (optional) ───────────────────────────────────────────────────
# Gmail: use an App Password (not your account password)
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
ALERT_FROM=your_email@gmail.com


# ── Portfolio trades (production seed) ────────────────────────────────────────
# Personal trades live in the `transactions` DB table. `transactions.csv`
# is git-ignored (public repo), so it never reaches the deployed container
# and the Portfolio tab would otherwise be empty in production.
#
# On first boot, if the `transactions` table is empty, it is auto-seeded
# from this variable. After the first seed the data lives in the database
# and this variable may be removed. Accepts either the raw CSV text or a
# base64-encoded CSV (auto-detected — use base64 if the Railway editor
# mangles multi-line values).
#
# Raw, multi-line example (header required):
#   TRANSACTIONS_CSV="user,ticker,date,quantity,price,currency,type
#   Ricardo,NVDA,2024-07-17,4,110.80,EUR,buy"
#
# Base64 example (POSIX):  base64 -w0 transactions.csv
#   TRANSACTIONS_CSV=dXNlcix0aWNrZXIsZGF0ZSwuLi4=
#
# Update trades later (the CSV grows as you trade):
#   python -m ingestion.transactions sync transactions.csv
#   python -m ingestion.transactions sync --from-env
TRANSACTIONS_CSV=


# ── Data settings ─────────────────────────────────────────────────────────────

# How many years of price history to fetch on setup
YEARS_BACK=10

# Screener universe size:
#   "all"            → all ~7000 FMP tickers (setup takes ~40 min)
#   500              → top 500 by market cap (setup takes ~8 min, recommended)
#   "AAPL,MSFT,..."  → specific tickers only
SCREENER_UNIVERSE=all


# ── App server ────────────────────────────────────────────────────────────────

# Set to "false" in production
DEBUG=true
PORT=8050
HOST=127.0.0.1


# ── Nightly scheduler (UTC) ───────────────────────────────────────────────────
# Prices refresh at HH:MM UTC every day
NIGHTLY_CRON_HOUR=22
NIGHTLY_CRON_MINUTE=0
